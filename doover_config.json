{
    "4_20ma_sensor": {
        "name": "4_20ma_sensor",
        "display_name": "4-20ma Sensor",
        "type": "DEV",
        "visibility": "PUB",
        "allow_many": true,
        "description": "An app for simply convert a 4-20mA signal to a value in the UI. Provide units, measuring range, an analogue input and some ranges and get a analogue value and a loading bar in your ui. ",
        "long_description": "README.md",
        "depends_on": [],
        "owner_org_key": "36a22e32-ab81-4a39-b400-869d532a052d",
        "image_name": "ghcr.io/getdoover/4-20ma-sensor:main",
        "container_registry_profile_key": "88953909-e9c4-4f81-9ec0-56239d4b0a2e",
        "build_args": "--platform linux/amd64,linux/arm64",
        "config_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "",
            "title": "$default",
            "type": "object",
            "properties": {
                "ai_pin_number": {
                    "title": "AI Pin Number",
                    "x-name": "ai_pin_number",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The analog input pin number for the 4-20mA sensor",
                    "default": 0,
                    "x-position": 0,
                    "minimum": 0,
                    "maximum": 15
                },
                "input_name": {
                    "title": "Input Name",
                    "x-name": "input_name",
                    "x-hidden": false,
                    "type": "string",
                    "x-required": true,
                    "description": "Name for the Input that appears in the UI e.g. Tank Vol (L)",
                    "x-position": 1
                },
                "min_range": {
                    "title": "Min Range",
                    "x-name": "min_range",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The physical value corresponding to 4mA signal (minimum sensor reading)",
                    "default": 0.0,
                    "x-position": 2
                },
                "max_range": {
                    "title": "Max Range",
                    "x-name": "max_range",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The physical value corresponding to 20mA signal (maximum sensor reading)",
                    "default": 100.0,
                    "x-position": 3
                },
                "measurement_units": {
                    "title": "Measurement Units",
                    "x-name": "measurement_units",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The units for the sensor measurement (e.g., %, \u00b0C, PSI, etc.)",
                    "default": null,
                    "x-position": 4
                },
                "enable_signal_filtering": {
                    "title": "Enable Signal Filtering",
                    "x-name": "enable_signal_filtering",
                    "x-hidden": false,
                    "type": [
                        "boolean",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Enable digital filtering to smooth out sensor readings",
                    "default": true,
                    "x-position": 5
                },
                "process_variance": {
                    "title": "Process Variance",
                    "x-name": "process_variance",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The process variance for the Kalman Filter running on the input",
                    "default": 0.5,
                    "x-position": 6
                },
                "sample_rate_hz": {
                    "title": "Sample Rate (Hz)",
                    "x-name": "sample_rate_hz",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "The sample rate in Hz for the main loop",
                    "default": 2.0,
                    "x-position": 7,
                    "minimum": 0.1,
                    "maximum": 5.0
                },
                "alarm": {
                    "title": "Alarm",
                    "x-name": "alarm",
                    "x-hidden": false,
                    "type": "object",
                    "x-required": true,
                    "description": "Alarm configuration",
                    "x-position": 8,
                    "properties": {
                        "alarm_threshold": {
                            "title": "Alarm Threshold",
                            "x-name": "alarm_threshold",
                            "x-hidden": false,
                            "type": [
                                "number",
                                "null"
                            ],
                            "x-required": false,
