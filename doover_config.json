                        "alarm_enabled": {
                            "title": "Alarm Enabled",
                            "x-name": "alarm_enabled",
                            "x-hidden": false,
                            "type": [
                                "boolean",
                                "null"
                            ],
                            "x-required": false,
                            "description": "Enable the alarm",
                            "default": false,
                            "x-position": 3
                        },
                        "alarm_active": {
                            "title": "Alarm Active",
                            "x-name": "alarm_active",
                            "x-hidden": false,
                            "type": [
                                "boolean",
                                "null"
                            ],
                            "x-required": false,
                            "description": "Enable the alarm",
                            "default": false,
                            "x-position": 4
                        },
                        "alarm_reset": {
                            "title": "Alarm Reset",
                            "x-name": "alarm_reset",
                            "x-hidden": false,
                            "type": [
                                "boolean",
                                "null"
                            ],
                            "x-required": false,
                            "description": "Reset the alarm",
                            "default": false,
                            "x-position": 5
                        }
                    },
                    "additionalElements": true,
                    "required": [],
                    "x-collapsible": true,
                    "x-defaultCollapsed": false
                }
            },
            "additionalElements": true,
            "required": [
                "input_name",
                "alarm"
            ]
        },
