                            "default": 0.0,
                            "x-position": 1,
                            "minimum": 0.0,
                            "maximum": 100.0
                        },
                        "alarm_message": {
                            "title": "Alarm Message",
                            "x-name": "alarm_message",
                            "x-hidden": false,
                            "type": [
                                "string",
                                "null"
                            ],
                            "x-required": false,
